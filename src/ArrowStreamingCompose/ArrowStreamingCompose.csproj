<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <!-- Data + the single numeric backbone (same TensorPrimitives the vendored kernel uses). -->
    <PackageReference Include="Apache.Arrow" Version="23.0.0" />
    <PackageReference Include="System.Numerics.Tensors" Version="10.0.9" />
    <!-- Pull (batch) and push (live) streaming surfaces. -->
    <PackageReference Include="System.Linq.Async" Version="6.0.1" />
    <PackageReference Include="System.Reactive" Version="6.0.1" />
  </ItemGroup>

</Project>
